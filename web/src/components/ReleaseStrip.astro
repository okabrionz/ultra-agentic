---
interface Props {
	release: {
		version: string;
		download: string;
	};
	source: string;
	variant?: 'card' | 'detail';
}

const { release, source, variant = 'card' } = Astro.props;
---

<div
	class:list={['release-strip', `release-strip-${variant}`]}
	aria-label={`Release ${release.version}`}
>
	<span class="release-status">Available v{release.version}</span>
	<div class="release-actions">
		<a class="download-action" href={release.download} download>
			{variant === 'detail' ? `Download v${release.version}` : 'Download ZIP'}
		</a>
		<a class="source-action" href={source}>Source <span aria-hidden="true">↗</span></a>
	</div>
</div>

<style>
	.release-strip {
		position: relative;
		z-index: 2;
		display: grid;
		min-width: 0;
		gap: 0.6rem;
		padding: 0.7rem;
		border: 1px solid color-mix(in srgb, var(--color-cobalt) 34%, var(--color-line));
		border-left: 0.22rem solid var(--color-cobalt);
		border-radius: var(--radius-control);
		background: var(--color-cobalt-soft);
	}

	.release-status {
		color: var(--color-cobalt-strong);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		font-weight: 700;
		letter-spacing: 0.035em;
	}

	.release-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.release-actions a {
		display: inline-flex;
		min-height: 2.75rem;
		align-items: center;
		justify-content: center;
		padding: 0.55rem 0.75rem;
		border: 1px solid var(--color-cobalt);
		border-radius: var(--radius-control);
		font-size: var(--text-sm);
		font-weight: 700;
		line-height: 1.2;
		text-decoration: none;
	}

	.download-action {
		background: var(--color-cobalt);
		color: white;
	}

	.download-action:hover {
		background: var(--color-cobalt-strong);
	}

	.source-action {
		background: var(--color-panel);
		color: var(--color-cobalt-strong);
	}

	.source-action:hover {
		background: white;
	}

	.release-strip-detail {
		margin-top: 0.9rem;
		background: color-mix(in srgb, var(--color-cobalt-soft) 72%, white);
	}

	@media (max-width: 26rem) {
		.release-actions {
			display: grid;
		}

		.release-actions a {
			width: 100%;
		}
	}
</style>
