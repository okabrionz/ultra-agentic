{
  "name": "deirs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:artifacts": "tsx --test tests/**/*.test.ts",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "package:downloads": "npm run build && tsx scripts/build-catalog-downloads.ts",
    "verify": "npm run test && npm run typecheck && npm run build && npm run test:artifacts"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "fflate": "^0.8.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
